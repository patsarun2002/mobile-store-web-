// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  user
  staff
  manager
}

enum UserStatus {
  active
  inactive
}

enum ProductStatus {
  instock
  reserved
  sold
  delete
}

enum SellStatus {
  pending
  paid
}

enum PaymentMethod {
  cash
  transfer
  credit_card
  installment
}

model User {
  id                  String         @id @default(auto()) @map("_id") @db.ObjectId
  name                String
  username            String         @unique
  password            String
  level               UserRole       @default(user)
  status              UserStatus     @default(active)
  tokenVersion        Int            @default(0)
  failedLoginAttempts Int            @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime?
  updatedAt           DateTime?
  refreshTokens       RefreshToken[]

  @@index([status])
  @@index([level, status])
}

model Company {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  address   String
  phone     String
  email     String?
  taxCode   String
  createdAt DateTime?
  updatedAt DateTime?
}

model Product {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  serial          String        @unique
  name            String
  release         String
  color           String
  price           Int
  costPrice       Int           @default(0)
  customerName    String
  customerPhone   String
  customerAddress String
  remark          String
  status          ProductStatus @default(instock)
  sell            Sell[]
  createdAt       DateTime?
  updatedAt       DateTime?

  @@index([status])
  @@index([status, createdAt])
  @@index([customerPhone])
  @@index([status, color])
  @@index([status, release])
  @@index([name])
  @@index([customerName])
}

model Sell {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  productId       String        @db.ObjectId
  product         Product       @relation(fields: [productId], references: [id])
  status          SellStatus    @default(pending)
  price           Int
  paymentMethod   PaymentMethod @default(cash)
  customerName    String?
  customerPhone   String?
  customerAddress String?
  payDate         DateTime?
  createdAt       DateTime?
  updatedAt       DateTime?

  @@index([status])
  @@index([productId])
  @@index([status, createdAt])
  @@index([payDate])
  @@index([paymentMethod])
}

model Service {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  price     Int
  remark    String?
  payDate   DateTime?
  createdAt DateTime?
  updatedAt DateTime?

  @@index([payDate])
}

model RefreshToken {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  token     String
  userId    String    @db.ObjectId
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime?
  updatedAt DateTime?

  @@index([token])
  @@index([userId])
}
